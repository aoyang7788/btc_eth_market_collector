[Unit]
Description=BTC ETH Market Collector V6
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/btc_eth_market_collector
ExecStart=/opt/btc_eth_market_collector/.venv/bin/python main.py --loop --interval 15
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
